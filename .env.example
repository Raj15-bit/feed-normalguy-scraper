SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=
# Optional. v1 ships in DeepSeek-only mode (OpenAI embeddings skipped).
# See main repo docs/INFRASTRUCTURE.md for the rule and the toggle.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Behaviour knobs (optional, sensible defaults if unset)
SCRAPER_MAX_FILINGS_PER_RUN=200
SCRAPER_BATCH_SIZE_EMBEDDINGS=100
SCRAPER_LOG_LEVEL=INFO

# OCR fallback for scanned PDFs (needs `tesseract-ocr` binary installed).
# Set to 0 to disable and revert to skip-scanned-PDF behaviour.
SCRAPER_OCR_ENABLED=1
SCRAPER_OCR_MAX_PAGES=30
SCRAPER_OCR_DPI=200

# DeepSeek 2-4 sentence summary written to filings.summary. Set to 0 to skip.
SCRAPER_SUMMARY_ENABLED=1

# Fail-loud: exit non-zero if failure rate exceeds this fraction of attempts.
SCRAPER_FAIL_THRESHOLD=0.20
